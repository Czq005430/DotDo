{
  "name": "dotdo",
  "private": true,
  "version": "1.0.2",
  "description": "A minimalist, MacOS-style floating task manager.",
  "author": "Albert Chen",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build:web": "tsc && vite build",
    "build": "npm run build:web && npm run fix:app-builder && electron-builder",
    "fix:app-builder": "chmod +x node_modules/app-builder-bin/mac/app-builder_*",
    "dist:mac": "npm run build:web && npm run fix:app-builder && node scripts/build-mac-dmg.cjs x64 arm64",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5187 && electron .\""
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.344.0",
    "postcss": "^8.4.49",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dotdo.desktop",
    "productName": "DotDo",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "DotDo Installer"
    }
  },
  "overrides": {
    "app-builder-bin": "4.2.0"
  }
}
